# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# Data (large files — never commit raw data)
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.fasta
*.fa
*.sra
genome_cache/
profiles/
humann3_out/
picrust2_out/
annotations/
data/                   # runtime cache; nothing here should be committed
models/*
!models/README.md
!models/agora2/MANIFEST.tsv

# Reference data (curated, not checked in)
reference/*.biom
reference/*.csv

# Databases
*.db
*.db-journal

# Receipts (generated at runtime)
receipts/*.json

# Results (generated at runtime)
results/
!results/.gitkeep

# IDE / OS
.DS_Store
.vscode/
*.swp
.idea/

# Secrets / credentials
.env
*.key

# Documents / binary assets (use docs/ for reference, never large binaries)
*.pdf
